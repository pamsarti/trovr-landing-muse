# Server-side env for the Cloudflare worker runtime in local dev.
# The @cloudflare/vite-plugin loads this file and exposes the values as
# process.env.* to SSR / server functions (these are NOT VITE_-prefixed).
#
# Copy to `.dev.vars` (gitignored) and fill from `npx supabase status`.
# Get the values with:  npx supabase status -o env

SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_PUBLISHABLE_KEY="<local anon key from supabase status>"
SUPABASE_SERVICE_ROLE_KEY="<local service_role key from supabase status>"
