# Client-side env for Vite (only VITE_-prefixed vars are injected into the
# browser bundle via import.meta.env). Copy to `.env.local` (gitignored).
# Get the anon key with:  npx supabase status -o env

VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_PUBLISHABLE_KEY="<local anon key from supabase status>"
VITE_SUPABASE_PROJECT_ID="trovr-landing-muse"
