# ─────────────────────────────────────────────────────────────────────────
# Trovr — environment variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────

# ── Admin Publisher dashboard ───────────────────────────────────────────────
# GitHub OAuth app (Settings → Developer settings → OAuth Apps).
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:5173/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Repository whose collaborators are authorized to publish. Anyone with Write,
# Maintain, or Admin permission on this repo can use the dashboard.
GITHUB_OWNER=
GITHUB_REPO=

# Secret used to encrypt and sign the session cookie. Must be at least 32 chars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Base URL of this app; used to build the OAuth callback URL. Must match the
# GitHub OAuth app configuration. Defaults to http://localhost:5173.
APP_URL=http://localhost:5173

# Netlify build hook that triggers a production deploy. Only used once the
# deploy service is switched from the local mock to the real implementation
# (src/lib/admin/deploy.server.ts → triggerDeploy). Never exposed to the client.
NETLIFY_DEPLOY_HOOK=

# ── Supabase (existing site integration) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
